    margin: 0;
  }

  .footer-disclaimer strong {
    color: #f59e0b;
  }

  .footer-bottom {
    text-align: center;
  }

  .footer-bottom p {
    color: #6b7280;
    font-size: 0.75rem;
    margin: 0.25rem 0;
  }

  .footer-note {
    font-style: italic;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
  }

  .footer-nav a {
    color: #9ca3af;
