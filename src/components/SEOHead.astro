---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://res.cloudinary.com/dhuc2wmhp/image/upload/f_auto,q_auto,w_1200/madrid-cannabis-guide/hero-madrid-gran-via.jpg',
  type = 'website',
  publishedDate,
  modifiedDate,
} = Astro.props;

const siteName = 'Madrid Cannabis Guide';
const siteUrl = 'https://madridcannabisguide.com';
const heroImage = 'https://res.cloudinary.com/dhuc2wmhp/image/upload/f_auto,q_auto,w_1400/madrid-cannabis-guide/hero-madrid-gran-via.jpg';

// FAQ structured data
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is cannabis legal in Madrid for tourists?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Cannabis is decriminalized for private use in Spain. Public consumption and purchase remain illegal with fines up to \u20ac600. Tourists can legally consume cannabis only inside licensed private social clubs through a valid membership invitation. Street purchases are always illegal regardless of nationality.',
      },
    },
    {
      '@type': 'Question',
      name: 'How can tourists access a cannabis social club in Madrid?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Tourists need a verified invitation from an existing member, a valid passport or EU ID proving they are 21+, and must pay a one-time membership fee (typically \u20ac20\u2013\u20ac50). Walk-ins are not accepted at legitimate clubs.',
      },
    },
    {
      '@type': 'Question',
      name: 'What are the fines for buying cannabis on the street in Madrid?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Buying or possessing cannabis in public spaces in Madrid carries administrative fines between \u20ac601 and \u20ac30,000 under Spain\'s Citizen Safety Law (Ley Mordaza). Police in tourist areas actively enforce these laws.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I bring cannabis from a Madrid social club to my hotel?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Transporting cannabis outside the club premises is illegal in Spain, even if you obtained it legally inside a licensed social club. Consumption must happen within the private club space. Carrying cannabis on public streets constitutes public possession and can result in fines starting at \u20ac601.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does it cost to join a cannabis social club in Madrid?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'One-time membership fees typically range from \u20ac20 to \u20ac50 at legitimate Madrid social clubs. Inside the club, product contributions vary but are generally comparable to or lower than street prices \u2014 with the critical difference of verified quality and full legal protection.',
      },
    },
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  description: 'The Official 2026 Guide to Cannabis Rules in Madrid for Tourists',
  inLanguage: 'en',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
};

// Article schema for main guide
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Madrid Cannabis Guide 2026: Legal Rules & Tourist Safety',
  description: description,
  image: ogImage,
  datePublished: '2026-03-09',
  dateModified: '2026-03-11',
  author: {
    '@type': 'Organization',
    name: siteName,
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: siteName,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': siteUrl,
  },
};

// Breadcrumb schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Madrid Cannabis Guide 2026',
      item: siteUrl,
    },
  ],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- LCP Preload: Hero image -->
<link rel="preload" as="image" href={heroImage} fetchpriority="high" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={siteName} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{publishedDate && <meta property="article:published_time" content={publishedDate} />}
{modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />