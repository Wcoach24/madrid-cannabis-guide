---
interface Props {
  variant?: 'inline' | 'banner';
}

const { variant = 'banner' } = Astro.props;
const isInline = variant === 'inline';
---

<aside
  class:list={[
    'premium-cta',
    { 'premium-cta--inline': isInline, 'premium-cta--banner': !isInline },
  ]}
  aria-label="Verified club invitation"
>
  <div class="premium-cta__badge">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M6.5 1L8 0l1.5 1L11 0l1 1.5L13.5 2l-.5 1.5L14 5l-1.5.5L13 7l-1.5.5-.5 1.5-1.5-.5L8 9.5 6.5 9 5 9.5l-.5-1.5L3 7.5 2 7l.5-1.5L2 4l1.5-.5L3 2l1.5-.5L5 0l1.5 1z" fill="#f59e0b"/>
      <path d="M6 7.5l1.5 1.5 3-3" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Editor's Choice \u2014 Verified Safe Route</span>
  </div>

  {!isInline && (
    <h3 class="premium-cta__title">Skip the Street Risks</h3>
  )}

  <p class="premium-cta__text">
    {isInline
      ? 'Skip the street risks. Get a verified invitation to Madrid\'s top-rated private club in 3 minutes.'
      : 'Avoid fines, scams, and unsafe street deals. Get a verified invitation to Madrid\'s top-rated private social club \u2014 safely and legally in just 3 minutes.'}
  </p>

  <a
    href="https://weedmadrid.com/invite"
    rel="sponsored noopener"
    target="_blank"
    class="premium-cta__button"
  >
    Get Your Verified Invitation
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>

  <p class="premium-cta__disclaimer">
    <small>This is a sponsored link to a third-party invitation service. Madrid Cannabis Guide receives compensation for referrals.</small>
  </p>
</aside>

<style>
  .premium-cta {
    border: 1px solid #1f2622;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.08), rgba(245, 158, 11, 0.06));
    position: relative;
    overflow: hidden;
  }

  .premium-cta--banner {
    padding: 2.5rem 2rem;
    text-align: center;
    margin: 3rem 0;
  }

  .premium-cta--inline {
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .premium-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #10b981, #f59e0b);
  }

  .premium-cta__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(245, 158, 11, 0.12);
    color: #f59e0b;
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .premium-cta__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e8ece9;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .premium-cta__text {
    color: #b8bdb8;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 1.5rem;
    max-width: 540px;
  }

  .premium-cta--banner .premium-cta__text {
    margin-left: auto;
    margin-right: auto;
  }

  .premium-cta__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .premium-cta__button:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.35);
  }

  .premium-cta__disclaimer {
    margin: 1rem 0 0;
    color: #6b7280;
    font-size: 0.7rem;
    line-height: 1.4;
  }
</style>
